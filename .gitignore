# NeverHuman — .gitignore

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Environment
.env
*.pem
*.key

# Runtime logs (never commit — gitkeep preserves the directory)
gary/logs/*
!gary/logs/.gitkeep
logs/*
!logs/.gitkeep

# Database
*.db
*.sqlite

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Models (large binary files — managed by install.sh and setup wizard)
models/
*.onnx
*.bin
*.safetensors

# NeverHuman runtime store
~/.neverhuman/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Certs (generated by start.sh — never commit)
cert.pem
key.pem
gary/cert.pem
gary/key.pem

# Temp
/tmp/neverhuman/
