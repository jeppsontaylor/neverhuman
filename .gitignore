# NeverHuman — .gitignore

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Environment
.env
*.pem
*.key

# Runtime logs (never commit — gitkeep preserves the directory)
gary/logs/*
!gary/logs/.gitkeep
logs/*
!logs/.gitkeep

# Database
*.db
*.sqlite

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Models (large binary files — managed by install.sh and setup wizard)
models/
*.onnx
*.safetensors

# flash-moe vendored engine — compiled artefacts and large runtime data (gitignored)
# Source files (.m, .c, .h, .metal, .py, Makefile) ARE committed
# Small prebuilt binaries (vocab.bin, tokenizer.bin) ARE committed
flash-moe/infer
flash-moe/chat
flash-moe/metal_infer
flash-moe/out_35b/
flash-moe/out_122b/
flash-moe/packed_experts*
flash-moe/*.air
flash-moe/*.metallib
flash-moe/*.o

# The expert_index_35b.json is committed (small, model-independent offsets)
# but the generated one from a specific run may differ; regenerated by build_expert_index_35b.py

# NeverHuman runtime store
~/.neverhuman/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Cached greeting audio (runtime-generated per voice by TTS — never commit)
gary/static/audio/voices/

# Certs (generated by start.sh — never commit)
cert.pem
key.pem
gary/cert.pem
gary/key.pem

# Temp
/tmp/neverhuman/
