# NeverHuman / GARY — Environment Configuration
# Copy to .env and fill in any overrides. All values shown are defaults.
# The server loads this file automatically on startup.

# ── Server ────────────────────────────────────────────────────────────────────
GARY_PORT=7861                        # HTTPS listening port
GARY_HOST=0.0.0.0                     # Bind address
GARY_TLS_CERT=cert.pem                # TLS certificate (relative to gary/)
GARY_TLS_KEY=key.pem                  # TLS private key

# ── LLM Inference Engine (flash-moe) ─────────────────────────────────────────
GARY_INFER_BIN=~/.neverhuman/flash-moe/infer   # Path to flash-moe binary
GARY_INFER_MODEL=                              # HF model dir (auto-detected if blank)
GARY_LLM_PORT=8088                             # Port flash-moe listens on
GARY_SKIP_AUTOLAUNCH=0                         # Set to 1 for setup-wizard-only mode

# ── Database (Postgres) ───────────────────────────────────────────────────────
GARY_DB_DSN=postgresql://gary:gary@localhost:5432/neverhuman

# ── Feature flags ─────────────────────────────────────────────────────────────
GARY_CONTEXT_PACK=1           # Enable DB-backed context pack (claims/loops/questions)
GARY_MIND_JSON=0              # Structured MindPulse JSON output (requires mindd)
GARY_PERSIST_MIND=0           # Write mind pulses to DB thoughts table
GARY_FILLER_AUDIO=1           # Play filler audio while LLM warms up

# ── Memory & performance ──────────────────────────────────────────────────────
GARY_MAX_HISTORY_TURNS=20     # Sliding context window (reduced to 10 when context pack on)
GARY_IS_SPEAKING_TIMEOUT=30   # Hard failsafe reset for is_speaking flag (seconds)
GARY_ASR_IDLE_TIMEOUT=300     # Unload ASR model after N seconds idle (saves ~1.2GB)

# ── HuggingFace ───────────────────────────────────────────────────────────────
# HUGGING_FACE_HUB_TOKEN=hf_...   # Required only for gated models
